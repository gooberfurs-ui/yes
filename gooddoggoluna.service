[Unit]
Description=GoodDoggoLuna Website
After=network.target

[Service]
Type=simple
User=nobody
WorkingDirectory=/path/to/your/website
ExecStart=/usr/bin/node /path/to/your/website/server.js
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
